# Forgotten Island — Bathala-Alam
# Streamlit secrets template
#
# HOW TO USE:
#   Local dev  → copy to .streamlit/secrets.toml and fill in your key
#   Streamlit Cloud → paste the key-value pair in the app's "Secrets" settings panel
#
# NEVER commit the real secrets.toml to version control.

GROQ_API_KEY = "your_groq_api_key_here"

# Fallback oracle — used automatically when Groq quota is exhausted
OPENAI_API_KEY = "your_openai_api_key_here"
