# === Secrets — NEVER commit these ===
.env
.streamlit/secrets.toml

# === Python cache ===
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# === Virtual environments ===
.venv/
venv/
env/
ENV/

# === HuggingFace model cache (large binary files) ===
# The pre-built vector store IS committed (see local_storage/vector_store/).
# The downloaded embedding model weights are NOT (re-downloaded at runtime).
local_storage/embedding_model/

# === Experimental vector stores (dev artefacts, not needed for production) ===
local_storage/experimental_vector_stores/

# === Evaluation results (CSV artefacts) ===
evaluation/evaluation_results/

# === macOS ===
.DS_Store
.AppleDouble
.LSOverride

# === IDE ===
.vscode/settings.json
.idea/

# === Jupyter ===
.ipynb_checkpoints/
